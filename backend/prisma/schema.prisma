generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  HR
  CANDIDATE
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
  HIRED
}

enum Role {
  user
  nova
}

// ─── Core identity ───────────────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String?
  createdAt   DateTime @default(now())
  stackUserId String   @unique
  role        UserRole

  hrProfile        HRProfile?
  candidateProfile CandidateProfile?
}

// ─── Role-specific profiles ───────────────────────────────────────────────────

model HRProfile {
  id             String  @id @default(uuid())
  userId         String  @unique
  companyName    String
  companyWebsite String?

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]
}

model CandidateProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  resumeKey String?
  skills    String[]

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  sessions     InterviewSession[]
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

model Job {
  id              String   @id @default(uuid())
  hrProfileId     String
  title           String
  description     String
  experienceLevel String?
  skills          String[]
  shareId         String   @unique @default(uuid())
  createdAt       DateTime @default(now())

  hr           HRProfile          @relation(fields: [hrProfileId], references: [id], onDelete: Cascade)
  applications Application[]
  sessions     InterviewSession[]

  @@index([hrProfileId])
}

// ─── Applications ─────────────────────────────────────────────────────────────

model Application {
  id                 String            @id @default(uuid())
  jobId              String
  candidateProfileId String
  status             ApplicationStatus @default(PENDING)
  coverNote          String?
  appliedAt          DateTime          @default(now())

  job              Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  sessions         InterviewSession[]

  @@unique([jobId, candidateProfileId])
  @@index([jobId])
  @@index([candidateProfileId])
}

// ─── Interview sessions ───────────────────────────────────────────────────────

model InterviewSession {
  id                 String    @id @default(uuid())
  jobId              String
  applicationId      String
  candidateProfileId String
  isCompleted        Boolean   @default(false)
  startedAt          DateTime  @default(now())
  endedAt            DateTime?
  recordingKey       String?

  job              Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  application      Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  transcript       Transcript[]

  @@index([jobId])
  @@index([applicationId])
  @@index([candidateProfileId])
}

// ─── Transcripts ──────────────────────────────────────────────────────────────

model Transcript {
  id        String   @id @default(uuid())
  sessionId String
  role      Role
  content   String
  timestamp DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}