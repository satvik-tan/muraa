
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String?
  createdAt   DateTime @default(now())
  stackUserId String   @unique

  hrModel          HRModel?
  candidatesModel  CandidatesModel?
  jobs             Job[]
  sessions         InterviewSession[]
  applications     JobApplication[]
  inmail           InMail[]
}

model HRModel {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CandidatesModel {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Job {
  id              String   @id @default(uuid())
  userId          String
  title           String
  description     String
  companyName     String?
  experienceLevel String?  // "Junior" | "Mid" | "Senior"
  skills          String[] // Postgres TEXT[] array
  shareId         String   @unique @default(uuid())
  createdAt       DateTime @default(now())

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions     InterviewSession[]
  applications JobApplication[]
  inmail       InMail[]

  @@index([userId])
}

model InterviewSession {
  id             String    @id @default(uuid())
  userId         String?   // nullable — guest candidates have no account
  jobId          String    // @unique removed — many sessions per job
  candidateName  String?
  candidateEmail String?
  isCompleted    Boolean   @default(false)
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  recordingKey String?

  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  job        Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  transcript Transcript[]

  @@index([userId])
  @@index([jobId])
}

model Transcript {
  id        String   @id @default(uuid())
  sessionId String
  role      Role
  content   String
  timestamp DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model JobApplication {
  id              String            @id @default(uuid())
  userId          String
  jobId           String
  applicationText String
  status          ApplicationStatus @default(pending)
  createdAt       DateTime          @default(now())
  approvedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  inmail InMail?

  @@unique([jobId, userId])
  @@index([userId])
  @@index([jobId])
}

model InMail {
  id            String   @id @default(uuid())
  userId        String
  jobId         String
  applicationId String   @unique
  subject       String
  body          String
  createdAt     DateTime @default(now())

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  job         Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobId])
}

enum Role {
  user
  nova
}

enum ApplicationStatus {
  pending
  approved
  rejected
}
